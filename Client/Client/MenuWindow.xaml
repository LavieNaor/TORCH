<Window x:Class="TorClient.MenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chat App" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#0f0f1a" FontFamily="Segoe UI"
        MinWidth="800" MinHeight="500"
        Closing="exitApp">

    <Window.Resources>
        <!-- Color Brushes -->
        <SolidColorBrush x:Key="BgPrimary" Color="#0f0f1a"/>
        <SolidColorBrush x:Key="BgSecondary" Color="#1a1a2e"/>
        <SolidColorBrush x:Key="BgChat" Color="#0a0a15"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#667eea"/>
        <SolidColorBrush x:Key="AccentLight" Color="#7c8ff8"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#e8e8f0"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#8888a8"/>
        <SolidColorBrush x:Key="TextMuted" Color="#555570"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#1a1a30"/>
        <SolidColorBrush x:Key="ReceivedBubble" Color="#1e1e35"/>
        <SolidColorBrush x:Key="OnlineDot" Color="#43e97b"/>
        <LinearGradientBrush x:Key="AccentGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#667eea" Offset="0"/>
            <GradientStop Color="#764ba2" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="PinkGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#f093fb" Offset="0"/>
            <GradientStop Color="#f5576c" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="CyanGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#4facfe" Offset="0"/>
            <GradientStop Color="#00f2fe" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="GreenGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#43e97b" Offset="0"/>
            <GradientStop Color="#38f9d7" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="OrangeGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#fa709a" Offset="0"/>
            <GradientStop Color="#fee140" Offset="1"/>
        </LinearGradientBrush>

        <!-- Icon Button Style -->
        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="38"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10" Padding="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#15FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Popup Menu Item Style -->
        <Style x:Key="PopupItemStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="10" Padding="10,10,14,10">
                            <ContentPresenter HorizontalAlignment="Left"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#33667eea"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Conversation Item Template -->
        <DataTemplate x:Key="ConversationTemplate">
            <Border Padding="12,10" CornerRadius="12" Cursor="Hand"
                    Background="Transparent" Margin="4,2"
                    MouseLeftButtonDown="Conversation_Click">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#15FFFFFF"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="42"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Width="42" Height="42" CornerRadius="14"
                            Background="{Binding AvatarBrush}">
                        <TextBlock Text="{Binding Initial}" Foreground="White"
                                   FontWeight="SemiBold" FontSize="16"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <DockPanel>
                            <TextBlock Text="{Binding Time}" DockPanel.Dock="Right"
                                       Foreground="{StaticResource TextMuted}" FontSize="11"/>
                            <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextPrimary}"
                                       FontWeight="SemiBold" FontSize="14"/>
                        </DockPanel>
                        <DockPanel Margin="0,4,0,0">
                            <Border DockPanel.Dock="Right" CornerRadius="10"
                                    Background="{StaticResource AccentBrush}"
                                    Padding="6,2" Margin="8,0,0,0"
                                    Visibility="{Binding UnreadVisibility}">
                                <TextBlock Text="{Binding Unread}" Foreground="White"
                                           FontSize="11" FontWeight="SemiBold"
                                           HorizontalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="{Binding Preview}" Foreground="{StaticResource TextSecondary}"
                                       FontSize="13" TextTrimming="CharacterEllipsis"/>
                        </DockPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════════ SIDEBAR ═══════════════ -->
        <Border Grid.Column="0" Background="{StaticResource BgSecondary}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- Sidebar Header -->
                <DockPanel DockPanel.Dock="Top" Margin="20,20,20,12">
                    <Grid DockPanel.Dock="Right">
                        <Button Style="{StaticResource IconButtonStyle}" ToolTip="New Chat"
                                Click="NewChatButton_Click">
                            <TextBlock Text="+" FontSize="22" FontWeight="Light"
                                       Foreground="{StaticResource TextSecondary}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                        <Popup x:Name="NewChatPopup" StaysOpen="False" Placement="Bottom"
                               AllowsTransparency="True" HorizontalOffset="-70">
                            <Border Background="{StaticResource BgSecondary}" CornerRadius="14"
                                    Padding="6" BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1" MinWidth="180">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="32" Opacity="0.5" ShadowDepth="8"/>
                                </Border.Effect>
                                <StackPanel>
                                    <Button Style="{StaticResource PopupItemStyle}"
                                            Click="NewPrivateChat_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#x1F4AC;" FontSize="18" Width="24"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Text="New Private Chat"
                                                       Foreground="{StaticResource TextPrimary}"
                                                       FontSize="14" Margin="10,0,0,0"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource PopupItemStyle}"
                                            Click="NewGroup_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#x1F465;" FontSize="18" Width="24"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Text="New Group"
                                                       Foreground="{StaticResource TextPrimary}"
                                                       FontSize="14" Margin="10,0,0,0"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Border>
                        </Popup>
                    </Grid>
                    <StackPanel Orientation="Horizontal">
                        <Border Width="42" Height="42" CornerRadius="14"
                                Background="{StaticResource AccentGradient}">
                            <Grid>
                                <TextBlock Text="Y" Foreground="White" FontWeight="SemiBold"
                                           FontSize="16" HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                                <Ellipse Width="12" Height="12" Fill="{StaticResource OnlineDot}"
                                         Stroke="{StaticResource BgSecondary}" StrokeThickness="2.5"
                                         HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                         Margin="0,0,-1,-1"/>
                            </Grid>
                        </Border>
                        <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Name="UsernameTextBlock" Text="" Foreground="{StaticResource TextPrimary}"
                                       FontWeight="SemiBold" FontSize="15"/>
                            <TextBlock Text="Online" Foreground="{StaticResource OnlineDot}"
                                       FontSize="12"/>
                        </StackPanel>
                    </StackPanel>
                </DockPanel>

                <!-- Search Bar -->
                <Border DockPanel.Dock="Top" Margin="16,0,16,12" Padding="10,8"
                        CornerRadius="12" Background="#0AFFFFFF" BorderThickness="1"
                        BorderBrush="Transparent">
                    <DockPanel>
                        <TextBlock Text="&#x1F50D;" Foreground="{StaticResource TextMuted}"
                                   FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBox x:Name="SearchBox" Background="Transparent" BorderThickness="0"
                                 Foreground="{StaticResource TextPrimary}" FontSize="13"
                                 VerticalAlignment="Center" CaretBrush="{StaticResource AccentBrush}"
                                 TextChanged="SearchBox_TextChanged">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="TextBox">
                                                <Grid>
                                                    <TextBlock Text="Search conversations..."
                                                               Foreground="{StaticResource TextMuted}"
                                                               FontSize="13" VerticalAlignment="Center"
                                                               Visibility="{Binding PlaceholderVisibility, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                                    <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                                                </Grid>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                    </DockPanel>
                </Border>

                <!-- Conversations List -->
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="ConversationsList"
                                  ItemTemplate="{StaticResource ConversationTemplate}"
                                  Padding="4,0"/>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ═══════════════ CHAT AREA ═══════════════ -->
        <Border Grid.Column="1" Background="{StaticResource BgChat}">
            <DockPanel>
                <!-- Chat Header -->
                <Border x:Name="ChatHeader" DockPanel.Dock="Top" Padding="24,16"
                        Background="#CC1a1a2e" BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,0,0,1" Visibility="Collapsed">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <Button Style="{StaticResource IconButtonStyle}" ToolTip="Voice Call">
                                <Viewbox Width="20" Height="20">
                                    <Path Data="M6.6,10.8C8.2,13.5 10.5,15.8 13.2,17.4L15.3,15.3C15.5,15.1 15.9,15 16.2,15.1C17.2,15.4 18.3,15.6 19.5,15.6C20,15.6 20.5,16.1 20.5,16.6V19.5C20.5,20 20,20.5 19.5,20.5C10.9,20.5 3.5,13.1 3.5,4.5C3.5,4 4,3.5 4.5,3.5H7.5C8,3.5 8.5,4 8.5,4.5C8.5,5.7 8.7,6.8 9,7.8C9.1,8.1 9,8.5 8.8,8.7L6.6,10.8Z"
                                          Fill="{StaticResource TextSecondary}"/>
                                </Viewbox>
                            </Button>
                            <Button Style="{StaticResource IconButtonStyle}" ToolTip="Video Call" Margin="4,0">
                                <Viewbox Width="20" Height="20">
                                    <Path Data="M17,10.5V7C17,6.4 16.6,6 16,6H4C3.4,6 3,6.4 3,7V17C3,17.6 3.4,18 4,18H16C16.6,18 17,17.6 17,17V13.5L21,17.5V6.5L17,10.5Z"
                                          Fill="{StaticResource TextSecondary}"/>
                                </Viewbox>
                            </Button>
                            <Button Style="{StaticResource IconButtonStyle}" ToolTip="More">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Ellipse Width="4" Height="4" Fill="{StaticResource TextSecondary}"/>
                                    <Ellipse Width="4" Height="4" Fill="{StaticResource TextSecondary}" Margin="4,0"/>
                                    <Ellipse Width="4" Height="4" Fill="{StaticResource TextSecondary}"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="HeaderAvatar" Width="42" Height="42" CornerRadius="14"
                                    Background="{StaticResource AccentGradient}">
                                <Grid>
                                    <TextBlock x:Name="HeaderInitial" Text="A" Foreground="White"
                                               FontWeight="SemiBold" FontSize="16"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <Ellipse Width="12" Height="12" Fill="{StaticResource OnlineDot}"
                                             Stroke="{StaticResource BgChat}" StrokeThickness="2.5"
                                             HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                             Margin="0,0,-1,-1"/>
                                </Grid>
                            </Border>
                            <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                                <TextBlock x:Name="HeaderName" Text="Alice"
                                           Foreground="{StaticResource TextPrimary}"
                                           FontWeight="SemiBold" FontSize="16"/>
                                <TextBlock Text="Online" Foreground="{StaticResource OnlineDot}"
                                           FontSize="12"/>
                            </StackPanel>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- Message Input Area -->
                <Border x:Name="MessageInputArea" DockPanel.Dock="Bottom" Padding="20,16"
                        Background="#991a1a2e" BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,1,0,0" Visibility="Collapsed">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Margin="0,0,8,0">
                            <Button Style="{StaticResource IconButtonStyle}" ToolTip="Attach">
                                <Viewbox Width="18" Height="18">
                                    <Path Data="M16.5,6V17.5C16.5,19.7 14.7,21.5 12.5,21.5C10.3,21.5 8.5,19.7 8.5,17.5V5C8.5,3.6 9.6,2.5 11,2.5C12.4,2.5 13.5,3.6 13.5,5V15.5C13.5,16.1 13,16.5 12.5,16.5C12,16.5 11.5,16.1 11.5,15.5V6H10V15.5C10,16.9 11.1,18 12.5,18C13.9,18 15,16.9 15,15.5V5C15,2.8 13.2,1 11,1C8.8,1 7,2.8 7,5V17.5C7,20.5 9.5,23 12.5,23C15.5,23 18,20.5 18,17.5V6H16.5Z"
                                          Fill="{StaticResource TextSecondary}"/>
                                </Viewbox>
                            </Button>
                            <Button Style="{StaticResource IconButtonStyle}" ToolTip="Emoji"
                                    Click="EmojiButton_Click">
                                <Viewbox Width="18" Height="18">
                                    <Path Data="M12,2C6.5,2 2,6.5 2,12C2,17.5 6.5,22 12,22C17.5,22 22,17.5 22,12C22,6.5 17.5,2 12,2ZM12,20C7.6,20 4,16.4 4,12C4,7.6 7.6,4 12,4C16.4,4 20,7.6 20,12C20,16.4 16.4,20 12,20ZM15.5,11C16.3,11 17,10.3 17,9.5C17,8.7 16.3,8 15.5,8C14.7,8 14,8.7 14,9.5C14,10.3 14.7,11 15.5,11ZM8.5,11C9.3,11 10,10.3 10,9.5C10,8.7 9.3,8 8.5,8C7.7,8 7,8.7 7,9.5C7,10.3 7.7,11 8.5,11ZM12,17.5C14.3,17.5 16.3,16.1 17.1,14H6.9C7.7,16.1 9.7,17.5 12,17.5Z"
                                          Fill="{StaticResource TextSecondary}"/>
                                </Viewbox>
                            </Button>
                        </StackPanel>

                        <Border DockPanel.Dock="Right" Width="44" Height="44" CornerRadius="14"
                                Background="{StaticResource AccentGradient}" Cursor="Hand"
                                Margin="8,0,0,0" MouseLeftButtonDown="SendButton_Click">
                            <Viewbox Width="20" Height="20" HorizontalAlignment="Center"
                                     VerticalAlignment="Center">
                                <Path Data="M2,21L23,12L2,3V10L17,12L2,14V21Z" Fill="White"/>
                            </Viewbox>
                        </Border>

                        <Border CornerRadius="14" Background="#0AFFFFFF"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                Padding="2">
                            <TextBox x:Name="MessageInput" Background="Transparent"
                                     BorderThickness="0" Foreground="{StaticResource TextPrimary}"
                                     FontSize="14" Padding="12,8" AcceptsReturn="False"
                                     CaretBrush="{StaticResource AccentBrush}"
                                     KeyDown="MessageInput_KeyDown"
                                     VerticalAlignment="Center">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="TextBox">
                                                    <Grid>
                                                        <TextBlock Text="Type a message..."
                                                                   Foreground="{StaticResource TextMuted}"
                                                                   FontSize="14" VerticalAlignment="Center"
                                                                   Margin="12,0,0,0"
                                                                   Visibility="{Binding MessagePlaceholderVisibility, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                                        <ScrollViewer x:Name="PART_ContentHost"
                                                                      VerticalAlignment="Center"/>
                                                    </Grid>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </Border>
                    </DockPanel>
                </Border>

                <Grid>
                    <!-- Empty State -->
                    <StackPanel x:Name="EmptyState" VerticalAlignment="Center"
                                HorizontalAlignment="Center" Opacity="0.6">
                        <TextBlock Text="&#x1F4AC;" FontSize="100" HorizontalAlignment="Center"
                                   Margin="0,0,0,16" Foreground="White"/>
                        <TextBlock Text="Select a conversation to start chatting"
                                   Foreground="White" FontSize="40"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- User Picker -->
                    <DockPanel x:Name="UserPickerPanel" Visibility="Collapsed">
                        <Border DockPanel.Dock="Top" Padding="20,16"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                            <DockPanel>
                                <Button DockPanel.Dock="Left" Style="{StaticResource IconButtonStyle}"
                                        Click="UserPickerBack_Click" ToolTip="Back">
                                    <TextBlock Text="&#x2190;" FontSize="18"
                                               Foreground="{StaticResource TextSecondary}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Button>
                                <Button x:Name="UserPickerDoneBtn" DockPanel.Dock="Right"
                                        Visibility="Collapsed" Click="UserPickerDone_Click"
                                        Cursor="Hand" Margin="8,0,0,0">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="Bd" Background="{StaticResource AccentGradient}"
                                                                CornerRadius="20" Padding="16,8">
                                                            <ContentPresenter HorizontalAlignment="Center"
                                                                              VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                    <TextBlock x:Name="UserPickerDoneText" Text="Done (0)"
                                               Foreground="White" FontSize="14" FontWeight="SemiBold"/>
                                </Button>
                                <TextBlock x:Name="UserPickerTitle" Text="Select User"
                                           Foreground="{StaticResource TextPrimary}"
                                           FontSize="18" FontWeight="SemiBold"
                                           VerticalAlignment="Center" Margin="12,0,0,0"/>
                            </DockPanel>
                        </Border>

                        <Border x:Name="GroupNamePanel" DockPanel.Dock="Top" Padding="20,12"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                                Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="Group Name" Foreground="{StaticResource TextSecondary}"
                                           FontSize="12" Margin="0,0,0,6"/>
                                <Border Background="{StaticResource BgSecondary}" CornerRadius="10"
                                        Padding="12,8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                    <TextBox x:Name="GroupNameInput" Background="Transparent" BorderThickness="0"
                                             Foreground="{StaticResource TextPrimary}" FontSize="14"
                                             CaretBrush="White" SelectionBrush="#667eea"
                                             VerticalAlignment="Center" MaxLength="50">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="TextBox">
                                                            <ScrollViewer x:Name="PART_ContentHost"/>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>
                                </Border>
                            </StackPanel>
                        </Border>

                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12,8">
                            <StackPanel x:Name="UserListPanel"/>
                        </ScrollViewer>
                    </DockPanel>

                    <!-- Messages Area -->
                    <ScrollViewer x:Name="MessagesScroll" VerticalScrollBarVisibility="Auto"
                                  Padding="24,20" Visibility="Collapsed">
                        <StackPanel x:Name="MessagesPanel" Margin="0,0,0,10"/>
                    </ScrollViewer>
                </Grid>
            </DockPanel>
        </Border>

        <!-- Emoji Picker Popup -->
        <Popup x:Name="EmojiPopup" StaysOpen="False" Placement="Top"
               PlacementTarget="{Binding ElementName=MessageInput}"
               HorizontalOffset="-50" VerticalOffset="-10"
               AllowsTransparency="True">
            <Border Background="{StaticResource BgSecondary}" CornerRadius="16"
                    Padding="12" BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="32" Opacity="0.4" ShadowDepth="8"/>
                </Border.Effect>
                <ItemsControl x:Name="EmojiGrid">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel MaxWidth="320"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="36" Height="36" CornerRadius="8" Cursor="Hand"
                                    Background="Transparent" MouseLeftButtonDown="Emoji_Click">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#15FFFFFF"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding}" FontSize="22"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>
        </Popup>
    </Grid>
</Window>
